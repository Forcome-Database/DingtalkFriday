# ============================================
# DingtalkFriday - 统一环境配置
# 复制为 .env 并填写实际值
# ============================================

# ---------- 端口 ----------
FRONTEND_PORT=80
BACKEND_PORT=8000

# ---------- 钉钉 API ----------
DINGTALK_APP_KEY=your_app_key
DINGTALK_APP_SECRET=your_app_secret
DINGTALK_BASE_URL=https://oapi.dingtalk.com
DINGTALK_CORP_ID=your_corp_id          # H5微应用免登录必填

# ---------- 数据库 ----------
DATABASE_URL=sqlite+aiosqlite:///./data/leave.db

# ---------- 业务配置 ----------
ROOT_DEPT_ID=55205497                  # 根部门ID，同步起始节点
LEAVE_TYPE_NAMES=                      # 显示的假期类型(逗号分隔，留空=全部)
ADMIN_USERID=your_admin_userid         # 钉钉管理员userid，API操作人身份

# ---------- 认证 ----------
ADMIN_PHONES=13800138000               # 管理员手机号(逗号分隔，支持多个)
JWT_SECRET=your-jwt-secret-change-me   # JWT签名密钥，生产环境务必修改
JWT_EXPIRE_HOURS=24                    # JWT过期时间(小时)

# ---------- 请假数据定时同步 ----------
# cron表达式，留空=禁用，示例: "0 2 * * *" = 每天凌晨2点
SYNC_CRON=

# ---------- 出差/外出数据定时同步 ----------
TRIP_SYNC_ENABLED=true                 # 是否启用出差同步(true/false)
TRIP_SYNC_CRON=30 2 * * *             # 出差同步cron表达式，留空=禁用
TRIP_HOT_DAYS_PAST=3                   # 热区：回溯过去天数(每次必同步)
TRIP_HOT_DAYS_FUTURE=7                 # 热区：预取未来天数(每次必同步)
TRIP_WARM_DAYS_FUTURE=90               # 温区：预取未来天数(仅周一同步)
TRIP_SYNC_CONCURRENCY=10               # API并发请求数
TRIP_SYNC_RETRY_COUNT=3                # 单次请求失败重试次数
TRIP_SYNC_FAIL_THRESHOLD=50            # 连续失败达此数则中止同步

# ---------- 开发模式 ----------
# 启用手机号直接登录(跳过钉钉验证)，生产环境务必设为 false
DEV_MODE=false
